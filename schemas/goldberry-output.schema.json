{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/goldberry-output.schema.json",
  "title": "GoldBerry Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "corrected_framing",
    "executive_summary",
    "power_knowledge_audit",
    "whats_missing",
    "cross_cultural_analysis",
    "synthesis",
    "solution_pathways",
    "cmr_score",
    "score_caveat",
    "lens_limitations",
    "next_step_beyond_goldberry"
  ],
  "properties": {
    "corrected_framing": {
      "type": "string",
      "minLength": 1
    },
    "executive_summary": {
      "type": "string",
      "minLength": 1
    },
    "power_knowledge_audit": {
      "type": "string",
      "minLength": 1
    },
    "whats_missing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "indigenous_knowledge",
        "deep_history",
        "cross_cultural_wisdom",
        "scientific_evidence",
        "artistic_perception",
        "future_modelling",
        "marginalised_voices"
      ],
      "properties": {
        "indigenous_knowledge": {
          "type": "string",
          "minLength": 1
        },
        "deep_history": {
          "type": "string",
          "minLength": 1
        },
        "cross_cultural_wisdom": {
          "type": "string",
          "minLength": 1
        },
        "scientific_evidence": {
          "type": "string",
          "minLength": 1
        },
        "artistic_perception": {
          "type": "string",
          "minLength": 1
        },
        "future_modelling": {
          "type": "string",
          "minLength": 1
        },
        "marginalised_voices": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cross_cultural_analysis": {
      "type": "string",
      "minLength": 1
    },
    "synthesis": {
      "type": "string",
      "minLength": 1
    },
    "solution_pathways": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cmr_score": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "score_caveat": {
      "type": "string",
      "minLength": 1
    },
    "lens_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_step_beyond_goldberry": {
      "type": "string",
      "minLength": 1
    }
  }
}
